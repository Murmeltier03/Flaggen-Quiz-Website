# Supabase/Vercel integration variables
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_YOUR_SERVER_KEY

# Optional compatibility aliases for manually configured/local environments.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_SERVER_KEY

# Long random string used to sign the player cookie.
PLAYER_COOKIE_SECRET=replace-with-at-least-32-random-characters
